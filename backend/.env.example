PORT=8080
NODE_ENV=development

# PostgreSQL — local dùng docker, production dùng Neon
DATABASE_URL=postgresql://learnex_user:learnex_pass@localhost:5432/learnex_db

# Redis — local dùng docker, production dùng Upstash
REDIS_URL=redis://:learnex_redis_pass@localhost:6379

# JWT
JWT_SECRET=change_this_to_64_random_chars
JWT_EXPIRES_IN=24h

# Cloudinary (lấy free tại cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini (lấy free tại aistudio.google.com)
GEMINI_API_KEY=AIza_your_key

# Firebase (lấy free tại console.firebase.google.com)
FIREBASE_PROJECT_ID=your_project_id

# CORS — thêm domain sau khi deploy
CORS_ORIGINS=http://localhost:5173,http://localhost:3000